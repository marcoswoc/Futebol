@page "/register"
@attribute [Authorize(Roles = "admin")]
@using Futebol.Shared.Models.User;
@using Futebol.Web.Services;
@inject UserServiceClient UserService;
@inject SweetAlertService Swal;

<PageTitle>Register</PageTitle>

<EditForm Model="@model" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <MudGrid Justify="Justify.Center">
        <MudItem xs="12" sm="12">
            <MudCard Elevation="10">
                <MudCardHeader Class="pb-2">
                    <CardHeaderContent>
                        <MudText Typo="Typo.h5">Registrar</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pb-4 pl-8 pr-8 pt-2">
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="User Name" @bind-Value="model.UserName" For="@(()=> model.UserName)"  />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Email" @bind-Value="model.Email" For="@(()=> model.Email)"/>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Password" @bind-Value="model.Password" InputType="InputType.Password" For="@(()=> model.Password)" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Label="Confirm Password" @bind-Value="model.ConfirmPassword" InputType="InputType.Password" For="@(()=> model.ConfirmPassword)" />
                        </MudItem>
                    </MudGrid>
                    
                </MudCardContent>
                <MudCardActions Class="pb-4 pl-8 pr-8">
                    @if (load is false)
                    {

                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">Registrar</MudButton>
                    }
                    else
                    {
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                    }
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>

@code {
    private CreateUserModel model = new();
    private bool load;

    private async Task HandleValidSubmit()
    {
        load = true;
        var result = await UserService.CreateUserAsync(model);

        if (result.Success)
        {
            await Notificacao(result.Message, "success");
            model = new();
        }

        else
            await Notificacao(result.Message, "error");

        load = false;
    }

    private async Task Notificacao(string message, string icon)
    {
        var toast = Swal.Mixin(
            new()
                {
                    Toast = true,
                    Position = "top-end",
                    ShowConfirmButton = false,
                    Timer = 3000,
                    TimerProgressBar = true
                }
        );

        await toast.FireAsync(new() { Icon = icon, Title = message });
    }
}
