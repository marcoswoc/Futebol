@page "/login"
@using Futebol.Shared.Models.User;
@using Futebol.Web.Services;
@inject UserServiceClient UserService
@inject NavigationManager NavigationManager
@inject SweetAlertService Swal

<PageTitle>Login</PageTitle>



<MudCard Elevation="10" Class="pa-8" Style="width:350px;">
    <MudCardContent >
        <MudText Align="Align.Center" Typo="Typo.h5">Login</MudText>
        <MudTextField Label="Email" Variant="Variant.Outlined" @bind-Value="@loginModel.Email" />
        <MudTextField Label="Senha" InputType="InputType.Password" Variant="Variant.Outlined" @bind-Value="@loginModel.Password" />
    </MudCardContent>
    <MudCardActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleValidSubmit">Entrar</MudButton>
    </MudCardActions>
</MudCard>


