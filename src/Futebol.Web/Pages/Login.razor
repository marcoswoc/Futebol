@page "/login"
@using Futebol.Shared.Models.User;
@using Futebol.Web.Services;
@inject UserServiceClient UserService
@inject NavigationManager NavigationManager
@inject SweetAlertService Swal

<PageTitle>Login</PageTitle>

<EditForm Model="@loginModel" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator/>
    <MudCard Elevation="10" Class="pa-8" Style="width:350px;">
        <MudCardContent>
            <MudText Align="Align.Center" Typo="Typo.h5">Login</MudText>
            <MudTextField Label="Email" Variant="Variant.Outlined" @bind-Value="@loginModel.Email" For="@(() => loginModel.Email)" />
            <MudTextField Label="Senha" InputType="InputType.Password" Variant="Variant.Outlined" @bind-Value="@loginModel.Password" For="@(() => loginModel.Password)"/>
        </MudCardContent>
        <MudCardActions>
            @if (loggingIn is false)
            {
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">Entrar</MudButton>
            }
            else
            {
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            }

        </MudCardActions>
    </MudCard>
</EditForm>

@code {
    private LoginModel loginModel = new();
    private bool loggingIn;

    private async Task HandleValidSubmit()
    {
        loggingIn = true;
        var result = await UserService.LoginAsync(loginModel);

        if (result.Success)
            NavigationManager.NavigateTo("/");
        else
            await Notificacao(result.Message);


        loggingIn = false;
    }

    private async Task Notificacao(string message)
    {
        var toast = Swal.Mixin(
                new()
                {
                    Toast = true,
                    Position = "top-end",
                    ShowConfirmButton = false,
                    Timer = 3000,
                    TimerProgressBar = true
                }
        );

        await toast.FireAsync(new() { Icon = "error", Title = message });
    }
}