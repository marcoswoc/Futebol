@page "/round"
@attribute [Authorize(Roles = "admin")]
@inject RoundServiceClient RoundService;
@inject NotificationService NotificationService

<PageTitle>Round</PageTitle>

<MudGrid Justify="Justify.Center">
    <MudItem xs="12" sm="12">
        <EditForm Model="@model" OnValidSubmit="@HandleValidSubmit">
            <DataAnnotationsValidator />
            <MudCard Elevation="10">
                <MudCardHeader Class="pb-2">
                    <CardHeaderContent>
                        <MudText Typo="Typo.h5">Partidas</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pb-4 pl-8 pr-8 pt-2">
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudDatePicker Label="Data Inicio" @bind-Date="model.StartDate" For="@(() => model.StartDate)"/>                            
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudDatePicker Label="Data Final" @bind-Date="model.EndDate" For="@(() => model.EndDate)" />
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
                <MudCardActions Class="pb-4 pl-8 pr-8">
                    @if (loadModel is false)
                    {
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">Registrar</MudButton>
                    }
                    else
                    {
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                    }
                </MudCardActions>
            </MudCard>
        </EditForm>
    </MudItem>

    <MudItem xs="12" sm="12">
        <MudTable Items="@rounds" T="RoundModel" Loading="@loadRounds" FixedHeader="true" Height="350px">
            <HeaderContent>
                <MudTh>DataInicio</MudTh>
                <MudTh>DataFim</MudTh>
                <MudTh>Ativo</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DataInicio">@context.StartDate</MudTd>
                <MudTd DataLabel="DataFim">@context.EndDate</MudTd>
                <MudTd DataLabel="Ativo">@context.IsActive</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private List<RoundModel> rounds = new();
    private CreateRoundModel model = new();
    private bool loadModel;
    private bool loadRounds;

    protected override async Task OnInitializedAsync()
    {
        await GetAllRoundsAsyn();
    }

    private async Task GetAllRoundsAsyn()
    {
        loadRounds = true;
        var result = await RoundService.GetAllAsync();

        if (result.Success)
        {
            rounds = result.Data.ToList();
        }
        else
        {
            await NotificationService.Error("Erro ao obter dados");
        }

        loadRounds = false;

    }


    private async Task HandleValidSubmit()
    {
        loadModel = true;
        var result = await RoundService.CreateAsync(model);

        if (result.Success)
        {
            await NotificationService.Success(result.Message);
            model = new();
            await GetAllRoundsAsyn();
        }
        else
            await NotificationService.Error(result.Message);

        loadModel = false;
    }
}
